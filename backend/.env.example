# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_hex_string_minimum_256_bits

JWT_TTL_SECONDS=86400

# Free-text goals/injuries for the AI coach context (optional)
COACH_PROFILE_NOTES=Goal: hypertrophy. No injuries.
